# .gitignoreファイルを作成
echo "# Python
__pycache__/
*.py[cod]
*$py.class
*.so
venv/
env/
ENV/
.env

# Database
*.db
*.sqlite
*.sqlite3

# Node.js
node_modules/
npm-debug.log*
*.log

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp" > .gitignore